rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "monnajamal2000@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email']) &&
             data.uid is string && data.uid.size() < 128 &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 512)) &&
             (!('points' in data) || (data.points is number)) &&
             (!('earnedPoints' in data) || (data.earnedPoints is number)) &&
             (!('pepeBalance' in data) || (data.pepeBalance is number)) &&
             (!('role' in data) || (data.role in ['user', 'admin', 'advertiser', 'publisher'])) &&
             (!('savedBkashNumber' in data) || (data.savedBkashNumber is string && data.savedBkashNumber.size() < 20)) &&
             (!('savedFaucetPayEmail' in data) || (data.savedFaucetPayEmail is string && data.savedFaucetPayEmail.size() < 100)) &&
             (!('referralCode' in data) || (data.referralCode is string && data.referralCode.size() < 20)) &&
             (!('referredBy' in data) || (data.referredBy is string && data.referredBy.size() < 128)) &&
             (!('referralCount' in data) || (data.referralCount is number));
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['userId', 'method', 'accountNumber', 'amount', 'credits', 'status', 'createdAt']) &&
             data.userId is string &&
             data.method in ['bkash', 'faucetpay'] &&
             data.accountNumber is string &&
             data.amount is number &&
             data.credits is number &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['userId', 'method', 'accountNumber', 'points', 'pepeAmount', 'status', 'createdAt']) &&
             data.userId is string &&
             data.method in ['bkash', 'faucetpay'] &&
             data.accountNumber is string &&
             data.points is number &&
             data.pepeAmount is number &&
             data.status in ['pending', 'completed', 'rejected'];
    }

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow create: if isOwner(userId) &&
                      isValidUser(request.resource.data) &&
                      (!('earnedPoints' in request.resource.data) || request.resource.data.earnedPoints == 0) &&
                      (request.resource.data.get('role', 'user') in ['user', 'advertiser', 'publisher'] || (request.resource.data.get('role', 'user') == 'admin' && request.auth.token.email == "monnajamal2000@gmail.com"));
      allow update: if (isAdmin() && (resource.data.get('email', '') != "monnajamal2000@gmail.com" || request.resource.data.get('role', '') == resource.data.get('role', ''))) || 
                      (isOwner(userId) && 
                        isValidUser(request.resource.data) &&
                        request.resource.data.get('email', '') == resource.data.get('email', '') &&
                        request.resource.data.uid == resource.data.uid &&
                        (
                          request.resource.data.get('role', '') == resource.data.get('role', '') || 
                          (request.resource.data.get('role', '') in ['advertiser', 'publisher'] && resource.data.get('role', 'user') in ['user', 'advertiser', 'publisher'])
                        ) &&
                        (request.resource.data.get('role', '') != 'admin' || resource.data.get('role', '') == 'admin')
                      ) ||
                      (isAuthenticated() && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points', 'earnedPoints', 'referralCount', 'pepeBalance'])
                      );
    }

    match /referrals/{referralId} {
      allow list: if isAdmin();
      allow list: if isAuthenticated() && resource.data.referrerId == request.auth.uid;
      allow list: if isAuthenticated() && resource.data.referredUserId == request.auth.uid;
      allow get: if isAdmin() || (isAuthenticated() && (resource.data.referrerId == request.auth.uid || resource.data.referredUserId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.referredUserId == request.auth.uid;
    }

    match /offers/{offerId} {
      allow read: if (resource.data.status == 'active') || (isAuthenticated() && resource.data.creatorId == request.auth.uid) || isAdmin();
      allow list: if true; 
      allow create: if isAuthenticated() &&
                      request.resource.data.creatorId == request.auth.uid &&
                      request.resource.data.status == 'pending_admin';
      allow update: if isAdmin() || (isAuthenticated() && resource.data.creatorId == request.auth.uid && resource.data.status != 'active');
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.creatorId == request.auth.uid);
    }

    match /swaps/{swapId} {
      allow read: if isAuthenticated() &&
                    (request.auth.uid == resource.data.userId ||
                     request.auth.uid == resource.data.offerCreatorId ||
                     isAdmin());
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.status == 'pending';
      allow update: if isAdmin() || (isAuthenticated() &&
                      (request.auth.uid == resource.data.offerCreatorId ||
                       (request.auth.uid == resource.data.userId && request.resource.data.status == resource.data.status)));
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || (isAuthenticated() && query.limit <= 100);
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid && 
                      request.resource.data.status == 'pending' &&
                      isValidPayment(request.resource.data);
      allow update: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin() || (isAuthenticated() && query.limit <= 100);
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid && 
                      request.resource.data.status == 'pending' &&
                      isValidWithdrawal(request.resource.data);
      allow update: if isAdmin();
    }

    match /dailyJobs/{jobId} {
      allow read: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /dailyJobCompletions/{completionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /creditLogs/{logId} {
      allow read, list: if isAdmin();
      allow create: if isAdmin() && 
                      request.resource.data.adminId == request.auth.uid &&
                      request.resource.data.timestamp == request.time;
    }

    match /config/{configId} {
      allow read: if true;
      allow update: if isAdmin() || (
        isAuthenticated() && 
        (
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalUsers']) && request.resource.data.totalUsers == resource.data.totalUsers + 1) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalOffers']) && request.resource.data.totalOffers == resource.data.totalOffers + 1)
        )
      );
      allow create: if isAdmin() || (isAuthenticated() && configId == 'main' && !exists(/databases/$(database)/documents/config/main) && request.resource.data.totalUsers == 1);
      allow delete: if isAdmin();
    }

    match /passwordResetRequests/{requestId} {
      allow create: if request.resource.data.email is string && 
                      request.resource.data.email.size() > 0 &&
                      request.resource.data.status == 'pending' &&
                      request.resource.data.createdAt == request.time;
      allow read, list, update: if isAdmin();
    }
  }
}
